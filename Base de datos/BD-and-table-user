-- 1. Crear la base de datos
CREATE DATABASE IF NOT EXISTS taller_formularios
    CHARACTER SET utf8mb4
    COLLATE utf8mb4_unicode_ci;

-- 2. Seleccionar la base de datos
USE taller_formularios;

-- 3. Crear la tabla de usuarios
--    id        → clave primaria auto-incremental
--    nombre    → texto obligatorio (máx. 100 caracteres)
--    email     → texto obligatorio y único (máx. 150 caracteres)
--    password  → almacena el HASH generado por password_hash(), nunca texto plano
--    creado_en → marca de tiempo automática al insertar el registro

CREATE TABLE IF NOT EXISTS usuarios (
    id         INT          NOT NULL AUTO_INCREMENT,
    nombre     VARCHAR(100) NOT NULL,
    email      VARCHAR(150) NOT NULL UNIQUE,
    password   VARCHAR(255) NOT NULL,          -- password_hash() produce ~60 chars; 255 es seguro
    creado_en  TIMESTAMP    NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id)
) ENGINE=InnoDB
  DEFAULT CHARSET=utf8mb4
  COLLATE=utf8mb4_unicode_ci;

